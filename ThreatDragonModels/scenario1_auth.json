              "privilegeLevel": "",
              "threats": [
                {
                  "id": "4292dadf-b9dd-4077-84f1-4f8edd18c48d",
                  "title": "Session Token Manipulation",
                  "status": "Open",
                  "severity": "High",
                  "type": "Tampering",
                  "description": "Attacker intercepts or modifies the session cookie to hijack another user's authenticated session. Since there is no token signing, forged tokens may be accepted by the session manager.",
                  "mitigation": "Use HMAC-signed JWTs for session tokens. Set HttpOnly and Secure flags on all cookies. Implement token expiry and rotation after each request.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 10,
                  "score": "6"
                },
                {
                  "id": "deb54b48-e6e1-4465-adf9-549e38c0e718",
                  "title": "Username Enumeration",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Information disclosure",
                  "description": "Login error messages return different responses for wrong username versus wrong password, allowing an attacker to determine which usernames exist in the system.",
                  "mitigation": "Always return a single generic error: \"Invalid username or password\" regardless of which field is wrong. Apply consistent response timing to prevent timing-based enumeration.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 11,
                  "score": "4"
                },
                {
                  "id": "63c74b8f-1ad0-468b-a652-76ecf5ed4a0c",
                  "title": "Login Endpoint Flooding",
                  "status": "Open",
                  "severity": "High",
                  "type": "Denial of service",
                  "description": "Attacker sends thousands of rapid requests to the login endpoint, exhausting server resources and preventing legitimate users from authenticating.",
                  "mitigation": "Implement rate limiting per IP address. Use exponential backoff after repeated failures. Add CAPTCHA after request threshold is exceeded. Deploy a Web Application Firewall.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 12,
                  "score": "6"
                }
              ],
              "threatFrequency": {
                "spoofing": 0,
                "tampering": 2,
                "repudiation": 0,
                "informationDisclosure": 1,
                "denialOfService": 1,
                "elevationOfPrivilege": 0
              }
            }
